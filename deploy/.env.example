# DojoLM Production Environment Variables
# Copy to .env and fill in values before deployment
# Generate secrets with: openssl rand -hex 32

# API Authentication — required in production
NODA_API_KEY=
# API key role: admin | analyst | viewer (default: analyst if unset)
NODA_API_KEY_ROLE=analyst

# Database encryption key — at least 32 chars
# Generate with: openssl rand -base64 48
TPI_DB_ENCRYPTION_KEY=

# Storage backend: json | db (recommended: db for production)
TPI_STORAGE_BACKEND=db

# Admin credentials — created on first run via setup wizard
# Password must meet complexity: 12+ chars, uppercase, lowercase, digit, special char
TPI_ADMIN_USERNAME=admin
TPI_ADMIN_PASSWORD=

# Session TTL in hours
TPI_SESSION_TTL_HOURS=24

# CORS origins (comma-separated)
TPI_CORS_ORIGINS=https://dojo.bucc.internal

# Trusted internal IPs for proxy header forwarding (comma-separated)
TPI_TRUSTED_INTERNAL_IPS=

# Ollama base URL for LLM operations
OLLAMA_BASE_URL=http://localhost:11434

# LLM Guard HMAC signing key
GUARD_CONFIG_SECRET=
