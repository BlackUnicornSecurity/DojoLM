{
  "name": "bmad-cyber2-framework",
  "version": "2.3.2",
  "description": "Production-ready BMAD security and automation framework with comprehensive validation, authentication, and audit capabilities",
  "type": "module",
  "main": "./_bmad/framework/dist/index.js",
  "module": "./_bmad/framework/dist/index.js",
  "types": "./_bmad/framework/dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./_bmad/framework/dist/index.js",
      "types": "./_bmad/framework/dist/index.d.ts"
    },
    "./framework": {
      "import": "./_bmad/framework/dist/index.js",
      "types": "./_bmad/framework/dist/index.d.ts"
    },
    "./validators": {
      "import": "./_bmad/framework/dist/validators/index.js",
      "types": "./_bmad/framework/dist/validators/index.d.ts"
    },
    "./auth": {
      "import": "./_bmad/framework/dist/auth/index.js",
      "types": "./_bmad/framework/dist/auth/index.d.ts"
    },
    "./audit": {
      "import": "./_bmad/framework/dist/audit/index.js",
      "types": "./_bmad/framework/dist/audit/index.d.ts"
    }
  },
  "workspaces": [
    "_bmad/framework",
    ".claude/validators-node"
  ],
  "bin": {
    "bmad-cybersec": "tools/cli/bmad-cli.js",
    "bmad": "tools/cli/bmad-cli.js"
  },
  "scripts": {
    "build": "npm run build:framework && npm run build:validators",
    "build:framework": "cd _bmad/framework && npm run build",
    "build:validators": "cd .claude/validators-node && npm run build",
    "build:watch": "npm run build:framework -- --watch",
    "dev": "npm run build:watch",
    "test": "vitest run",
    "test:unit": "vitest run --config dev-tools/config/vitest.config.unit.ts",
    "test:integration": "vitest run --config dev-tools/config/vitest.config.integration.ts",
    "test:performance": "vitest run --config dev-tools/config/vitest.config.performance.ts",
    "test:regression": "vitest run --config dev-tools/config/vitest.config.regression.ts",
    "test:regression:critical": "vitest run --config dev-tools/config/vitest.config.regression-critical.ts",
    "test:memory": "vitest run --config dev-tools/config/vitest.config.performance.ts tests/performance/memory.test.ts",
    "test:bench": "vitest bench --config dev-tools/config/vitest.config.performance.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit && cd _bmad/framework && tsc --noEmit && cd ../../.claude/validators-node && tsc --noEmit",
    "security:scan": "npm audit --audit-level=moderate",
    "security:validate-framework": "node scripts/validate-security.js",
    "security:verify-validators": "node src/security/verify-validators.js",
    "security:generate-checksums": "node src/security/generate-validator-checksums.js",
    "check:bundle-size": "node scripts/check-bundle-size.js",
    "test:coverage:owasp": "node scripts/owasp-coverage.js",
    "validate:exports": "node scripts/validate-exports.js",
    "docs:generate": "typedoc --options typedoc.json",
    "docs:validate": "node scripts/validate-docs.js",
    "docs:check-readme": "node scripts/check-readme.js",
    "clean": "rm -rf dist _bmad/framework/dist .claude/validators-node/dist",
    "prepack": "npm run clean && npm run build",
    "postinstall": "npm run build",
    "quality:check": "npm run lint && npm run type-check && npm run test:coverage",
    "ci:quality": "npm run quality:check && npm run security:scan && npm run build",
    "modules": "node src/utility/tools/module-selector/index.js",
    "modules:offline": "node src/utility/tools/module-selector/index.js --offline",
    "install:offline": "npm install --offline",
    "cache:prepare": "npm pack && npm cache add *.tgz",
    "security:config": "node src/utility/tools/security-config/index.js",
    "llm:setup": "node src/utility/tools/llm-setup/index.js",
    "health": "node src/utility/tools/health-check/index.js",
    "pgp:setup": "node src/utility/tools/pgp-setup/index.js",
    "validate:refs": "node src/utility/tools/reference-validator/cli.js",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "test:schemas": "node tools/validate-agent-schema.js && node tools/validate-workflow-schema.js && node tools/validate-module-schema.js",
    "qa": "npm run test:schemas && npm run lint && npm run lint:md && npm test && bash scripts/security-regression.sh"
  },
  "keywords": [
    "bmad",
    "security",
    "framework",
    "typescript",
    "validation",
    "authentication",
    "rbac",
    "audit",
    "hooks",
    "enterprise",
    "production"
  ],
  "author": "Amelia (Dev) - BMAD Framework Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "fast-xml-parser": "5.3.4",
    "esbuild": ">=0.25.0"
  },
  "dependencies": {
    "@bmad/validators": "file:.claude/validators-node",
    "@clack/core": "^1.0.0",
    "@clack/prompts": "^1.0.0",
    "chalk": "^5.6.2",
    "commander": "^11.0.0",
    "fs-extra": "^11.3.3",
    "glob": "^10.5.0",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "tar": "^7.5.7",
    "zod": "^3.22.0"
  },
  "bundledDependencies": [
    "@clack/core",
    "@clack/prompts",
    "commander",
    "picocolors"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^20.10.0",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-yml": "^3.1.2",
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^1.1.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "files": [
    "_bmad/framework/dist/**/*",
    ".claude/validators-node/dist/**/*",
    "!**/__tests__/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "_bmad/framework/README.md",
    "tools/cli/**/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/bmad/bmad-cyber2.git"
  },
  "bugs": {
    "url": "https://github.com/bmad/bmad-cyber2/issues"
  },
  "homepage": "https://github.com/bmad/bmad-cyber2#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
