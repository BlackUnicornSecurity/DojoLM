# Production E2E Test Environment
# Copy to .env.e2e.prod and fill in values.
# .env.e2e.prod is gitignored via .env* pattern.
#
# Usage: E2E_TARGET=prod npm run test:e2e

# Production URL (Caddy reverse proxy on Voyager)
E2E_BASE_URL=https://dojo.bucc.internal

# Target flag (enables prod-specific Playwright config: mobile project, longer timeouts, full evidence capture)
E2E_TARGET=prod

# Optional: Basic auth credentials for smoke tests requiring login
# WARNING: Do not commit real credentials. Use this file locally only.
# E2E_ADMIN_USERNAME=
# E2E_ADMIN_PASSWORD=
