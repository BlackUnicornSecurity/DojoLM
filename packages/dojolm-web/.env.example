# DojoLM Web - Environment Variables
# Phase 6: Deployment Configuration

# Node Environment
NODE_ENV=production

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:42001
NEXT_PUBLIC_APP_URL=http://localhost:42001

# API Authentication (F-13)
# Required in production. All external API calls must include X-API-Key header with this value.
# Browser same-origin requests require a valid session cookie and this app origin.
# Generate with: openssl rand -hex 32
NODA_API_KEY=

# API Key Role Configuration (Security Fix: R8-007)
# Default role assigned to API key authenticated users.
# Valid values: admin, analyst, operator, auditor, viewer
# Defaults to 'analyst' (safe default with limited privileges) if not set or invalid.
NODA_API_KEY_ROLE=analyst

# Per-Key Role Mapping (Optional)
# JSON array mapping API key hashes to specific roles.
# Format: [{"keyHash": "abc123...", "role": "admin"}, ...]
# Key hash = first 16 chars of SHA-256(api_key). Use this to grant different roles per API key.
# API_KEY_PERMISSIONS=

# Scanner Configuration
NEXT_PUBLIC_MAX_TEXT_LENGTH=10000

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_ERROR_REPORTING=false

# Database Encryption (P2.5)
# Required: AES-256-GCM key for encrypting API keys at rest.
# Must be at least 32 characters. Generate with: openssl rand -base64 48
TPI_DB_ENCRYPTION_KEY=

# Storage Backend (P2.5)
# Options: json (default, file-based) | db (SQLite via better-sqlite3)
TPI_STORAGE_BACKEND=json

# Auth Configuration (P2.5)
# Initial admin account created on first run if no users exist
TPI_ADMIN_USERNAME=admin
TPI_ADMIN_PASSWORD=
TPI_SESSION_TTL_HOURS=24

# CORS Configuration (P2.5)
# Comma-separated list of allowed origins. Defaults to same-origin only.
TPI_CORS_ORIGINS=

# LLM Guard HMAC Signing (TPI-UIP-11)
# Required in production for guard config integrity. Generate with: openssl rand -hex 32
GUARD_CONFIG_SECRET=

# Deployment
PORT=42001
