{
  "name": "bu-tpi",
  "version": "1.0.0",
  "description": "TPI Security Test Lab - Prompt injection detection toolkit based on CrowdStrike taxonomy",
  "type": "module",
  "main": "./dist/scanner.js",
  "types": "./dist/scanner.d.ts",
  "exports": {
    ".": {
      "import": "./dist/scanner.js",
      "types": "./dist/scanner.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    },
    "./scanner": {
      "import": "./dist/scanner.js",
      "types": "./dist/scanner.d.ts"
    },
    "./llm": {
      "import": "./dist/llm/index.js",
      "types": "./dist/llm/index.d.ts"
    },
    "./llm/types": {
      "import": "./dist/llm/types.js",
      "types": "./dist/llm/types.d.ts"
    },
    "./llm/errors": {
      "import": "./dist/llm/errors.js",
      "types": "./dist/llm/errors.d.ts"
    },
    "./llm/test-helpers": {
      "import": "./dist/llm/test-helpers.js",
      "types": "./dist/llm/test-helpers.d.ts"
    },
    "./scanner-binary": {
      "import": "./dist/scanner-binary.js",
      "types": "./dist/scanner-binary.d.ts"
    },
    "./attackdna": {
      "import": "./dist/attackdna/index.js",
      "types": "./dist/attackdna/index.d.ts"
    },
    "./compliance": {
      "import": "./dist/compliance/index.js",
      "types": "./dist/compliance/index.d.ts"
    },
    "./sengoku": {
      "import": "./dist/sengoku/index.js",
      "types": "./dist/sengoku/index.d.ts"
    },
    "./timechamber": {
      "import": "./dist/timechamber/index.js",
      "types": "./dist/timechamber/index.d.ts"
    },
    "./kotoba": {
      "import": "./dist/kotoba/index.js",
      "types": "./dist/kotoba/index.d.ts"
    },
    "./benchmark": {
      "import": "./dist/benchmark/index.js",
      "types": "./dist/benchmark/index.d.ts"
    },
    "./edgefuzz": {
      "import": "./dist/edgefuzz/index.js",
      "types": "./dist/edgefuzz/index.d.ts"
    },
    "./defense": {
      "import": "./dist/defense/index.js",
      "types": "./dist/defense/index.d.ts"
    },
    "./supplychain": {
      "import": "./dist/supplychain/index.js",
      "types": "./dist/supplychain/index.d.ts"
    },
    "./transfer": {
      "import": "./dist/transfer/index.js",
      "types": "./dist/transfer/index.d.ts"
    },
    "./xray": {
      "import": "./dist/xray/index.js",
      "types": "./dist/xray/index.d.ts"
    },
    "./fingerprint": {
      "import": "./dist/fingerprint/index.js",
      "types": "./dist/fingerprint/index.d.ts"
    },
    "./shingan": {
      "import": "./dist/shingan/index.js",
      "types": "./dist/shingan/index.d.ts"
    },
    "./validation": {
      "import": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    }
  },
  "bin": {
    "tpi-lab": "./src/serve.ts",
    "tpi-scan": "./dist/cli/tpi-scan.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "mkdir -p dist/fingerprint && cp src/fingerprint/kagami-signatures.json dist/fingerprint/kagami-signatures.json",
    "start": "npx tsx src/serve.ts",
    "generate": "npx tsx src/generate-fixtures.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:regression": "npx tsx tools/test-regression.ts",
    "test:security": "npx tsx tools/test-security-fixes.ts",
    "test:all": "vitest run && npx tsx tools/test-regression.ts && npx tsx tools/test-security-fixes.ts",
    "test:api": "curl -s http://localhost:8089/api/run-tests",
    "validate:manifest": "npx tsx tools/validate-manifest.ts",
    "validation:evidence": "npx tsx tools/generate-katana-evidence.ts",
    "typecheck": "tsc --noEmit",
    "perf:scanner": "npx tsx tools/test-perf-scanner.ts",
    "perf:scanner:text": "npx tsx tools/test-perf-scanner.ts --type=text",
    "perf:scanner:binary": "npx tsx tools/test-perf-scanner.ts --type=binary",
    "perf:memory": "npx tsx tools/test-perf-memory.ts",
    "perf:regex": "npx tsx tools/test-perf-regex.ts",
    "perf:all": "npm run perf:scanner && npm run perf:memory && npm run perf:regex",
    "perf:baseline": "npm run perf:all -- --save-baseline"
  },
  "keywords": [
    "tpi",
    "prompt-injection",
    "security",
    "llm",
    "crowdstrike",
    "scanner",
    "testing",
    "cybersecurity"
  ],
  "author": "BU-TPI Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "exifr": "7.1.3",
    "music-metadata": "11.12.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
