{
  "name": "bu-tpi",
  "version": "1.0.0",
  "description": "TPI Security Test Lab - Prompt injection detection toolkit based on CrowdStrike taxonomy",
  "type": "module",
  "main": "./src/scanner.ts",
  "bin": {
    "tpi-lab": "./src/serve.ts"
  },
  "scripts": {
    "start": "npx tsx src/serve.ts",
    "generate": "npx tsx src/generate-fixtures.ts",
    "test": "npx tsx tools/test-regression.ts",
    "test:security": "npx tsx tools/test-security-fixes.ts",
    "test:all": "npx tsx tools/test-regression.ts && npx tsx tools/test-security-fixes.ts",
    "test:api": "curl -s http://localhost:8089/api/run-tests",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "tpi",
    "prompt-injection",
    "security",
    "llm",
    "crowdstrike",
    "scanner",
    "testing",
    "cybersecurity"
  ],
  "author": "BU-TPI Team",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "exifr": "7.1.3",
    "music-metadata": "11.12.1",
    "png-chunks-extract": "1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
