{
  "name": "@dojolm/scanner",
  "version": "1.0.0",
  "description": "Shared scanner logic for TPI Security Test Lab",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bu-tpi": "file:../bu-tpi"
  },
  "devDependencies": {
    "typescript": "^5.7.3"
  }
}
