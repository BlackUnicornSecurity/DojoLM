{
  "name": "dojolm-monorepo",
  "version": "1.0.0",
  "description": "DojoLM - LLM Red Teaming and Security Testing Platform with TPI Taxonomy",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:watch": "npm run build:watch --workspaces",
    "dev": "npm run dev --workspaces",
    "test": "npm test --workspaces",
    "test:watch": "npm run test:watch --workspaces",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces",
    "clean": "npm run clean --workspaces",
    "security:scan": "npm audit --audit-level=moderate",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "test:schemas": "node tools/validate-agent-schema.js && node tools/validate-workflow-schema.js && node tools/validate-module-schema.js",
    "qa": "npm run test:schemas && npm run lint && npm run lint:md && npm test && bash scripts/security-regression.sh"
  },
  "keywords": [
    "dojolm",
    "llm",
    "red-teaming",
    "tpi",
    "prompt-injection",
    "security-testing",
    "crowdstrike",
    "adversarial-ml",
    "ai-safety"
  ],
  "author": "DojoLM Team",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "inquirer": "^9.2.0",
    "zod": "^3.22.0",
    "commander": "^11.0.0",
    "ora": "^8.0.0",
    "@clack/core": "^1.0.0",
    "@clack/prompts": "^1.0.0",
    "fs-extra": "^11.3.3",
    "glob": "^10.5.0",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "tar": "^7.5.7"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.10.0",
    "vitest": "^1.1.0",
    "@eslint/js": "^9.39.2",
    "@types/semver": "^7.7.1",
    "@vitest/coverage-v8": "^1.1.0",
    "@vitest/ui": "^1.1.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.2",
    "eslint-plugin-unicorn": "^62.0.0",
    "eslint-plugin-yml": "^3.1.2",
    "markdownlint-cli2": "^0.20.0",
    "prettier": "^3.1.0",
    "tsx": "^4.6.0",
    "typedoc": "^0.25.0",
    "typescript-eslint": "^8.55.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dojolm/dojolm.git"
  },
  "bugs": {
    "url": "https://github.com/dojolm/dojolm/issues"
  },
  "homepage": "https://github.com/dojolm/dojolm#readme"
}
